<%- include('partials/header') %>

<div class="mb-6">
  <a href="/" class="text-gray-500 hover:text-green-400 text-sm">← Volver</a>
</div>

<div class="border border-gray-800 rounded p-6 mb-8">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-2xl text-white"><%= topic.titulo %></h1>
      <p class="text-gray-500 mt-2"><%= topic.descripcion %></p>
    </div>
    <div class="flex flex-col items-center ml-6">
      <button class="vote-btn text-green-400 hover:text-green-300 text-2xl" data-id="<%= topic._id %>" data-type="topic">▲</button>
      <span class="text-white font-bold text-xl vote-count"><%= topic.votos %></span>
    </div>
  </div>
  <div class="flex gap-3 mt-4">
    <a href="/topics/<%= topic._id %>/edit" class="text-sm text-gray-500 hover:text-green-400">Editar</a>
    <form action="/topics/<%= topic._id %>?_method=DELETE" method="POST">
      <button type="submit" class="text-sm text-gray-500 hover:text-red-400">Borrar</button>
    </form>
  </div>
</div>

<h2 class="text-lg text-green-400 mb-4">Enlaces</h2>

<% topic.enlaces.sort((a,b) => b.votos - a.votos).forEach(link => { %>
  <div class="border border-gray-800 rounded p-4 mb-3 hover:border-green-800 transition">
    <div class="flex justify-between items-center">
      <div>
        <a href="<%= link.url %>" target="_blank" class="text-green-400 hover:text-green-300"><%= link.url %></a>
        <p class="text-gray-500 text-sm mt-1"><%= link.descripcion %></p>
      </div>
      <div class="flex flex-col items-center ml-4">
        <button class="vote-btn text-green-400 hover:text-green-300 text-xl" data-id="<%= topic._id %>" data-link-id="<%= link._id %>" data-type="link">▲</button>
        <span class="text-white font-bold vote-count"><%= link.votos %></span>
      </div>
    </div>
    <div class="flex gap-3 mt-3">
      <form action="/topics/<%= topic._id %>/links/<%= link._id %>?_method=DELETE" method="POST">
        <button type="submit" class="text-xs text-gray-600 hover:text-red-400">Borrar enlace</button>
      </form>
    </div>
  </div>
<% }) %>

<div class="border border-gray-800 rounded p-4 mt-6">
  <h3 class="text-gray-400 text-sm mb-4">+ Agregar enlace</h3>
  <form action="/topics/<%= topic._id %>/links" method="POST" class="space-y-3">
    <input type="text" name="url" placeholder="https://..." required
      class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-2 text-white focus:outline-none focus:border-green-500"/>
    <input type="text" name="descripcion" placeholder="Descripción opcional"
      class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-2 text-white focus:outline-none focus:border-green-500"/>
    <button type="submit" class="bg-green-500 hover:bg-green-400 text-gray-950 px-4 py-2 rounded font-bold text-sm">Agregar</button>
  </form>
</div>

<%- include('partials/footer') %>