<%- include('partials/header') %>

<div class="mb-6">
  <a href="/" class="back-link">← Volver</a>
</div>

<div class="card">
  <div class="topic-card">
    <div>
      <h1 class="title-primary" style="font-size: 1.5rem;"><%= topic.titulo %></h1>
      <p class="text-muted" style="margin-top: 8px;"><%= topic.descripcion %></p>
    </div>
    <div class="vote-container">
      <button class="vote-btn" data-id="<%= topic._id %>" data-type="topic">▲</button>
      <span class="vote-count" style="font-size: 1.25rem;"><%= topic.votos %></span>
    </div>
  </div>
  <div style="display: flex; gap: 12px; margin-top: 16px;">
    <a href="/topics/<%= topic._id %>/edit" class="btn-text">Editar</a>
    <form action="/topics/<%= topic._id %>?_method=DELETE" method="POST">
      <button type="submit" class="btn-text btn-danger">Borrar</button>
    </form>
  </div>
</div>

<h2 class="title-primary" style="font-size: 1.1rem; margin-bottom: 16px;">Enlaces</h2>

<% topic.enlaces.sort((a,b) => b.votos - a.votos).forEach(link => { %>
  <div class="card topic-card" style="margin-bottom: 12px; padding: 12px;">
    <div style="display: flex; justify-content: space-between; width: 100%; align-items: center;">
      <div>
        <a href="<%= link.url %>" target="_blank" class="topic-link" style="font-size: 1rem;"><%= link.url %></a>
        <p class="text-muted text-small" style="margin-top: 4px;"><%= link.descripcion %></p>
        <form action="/topics/<%= topic._id %>/links/<%= link._id %>?_method=DELETE" method="POST" style="margin-top: 8px;">
            <button type="submit" class="btn-text btn-danger" style="font-size: 0.75rem;">Borrar enlace</button>
        </form>
      </div>
      <div class="vote-container">
        <button class="vote-btn" data-id="<%= topic._id %>" data-link-id="<%= link._id %>" data-type="link">▲</button>
        <span class="vote-count"><%= link.votos %></span>
      </div>
    </div>
  </div>
<% }) %>

<div class="card" style="margin-top: 24px;">
  <h3 class="text-muted" style="font-size: 0.875rem; margin-bottom: 12px;">+ Agregar enlace</h3>
  <form action="/topics/<%= topic._id %>/links" method="POST">
    <div class="form-group">
        <input type="text" name="url" placeholder="https://..." required class="input-field"/>
    </div>
    <div class="form-group">
        <input type="text" name="descripcion" placeholder="Descripción opcional" class="input-field"/>
    </div>
    <button type="submit" class="btn-primary" style="font-size: 0.875rem;">Agregar</button>
  </form>
</div>

<%- include('partials/footer') %>
