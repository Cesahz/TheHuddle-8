<%- include('partials/header') %>

<div class="mb-6">
  <a href="/" class="text-gray-500 hover:text-green-400 text-sm">← Volver</a>
</div>

<h1 class="text-2xl text-green-400 mb-8">Nuevo tema</h1>

<form action="/topics" method="POST" class="space-y-4">
  <div>
    <label class="text-gray-400 text-sm">Título</label>
    <input type="text" name="titulo" required
      class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-2 mt-1 text-white focus:outline-none focus:border-green-500"/>
  </div>
  <div>
    <label class="text-gray-400 text-sm">Descripción</label>
    <textarea name="descripcion" rows="3"
      class="w-full bg-gray-900 border border-gray-700 rounded px-4 py-2 mt-1 text-white focus:outline-none focus:border-green-500"></textarea>
  </div>
  <button type="submit" class="bg-green-500 hover:bg-green-400 text-gray-950 px-6 py-2 rounded font-bold">Crear tema</button>
</form>

<%- include('partials/footer') %>