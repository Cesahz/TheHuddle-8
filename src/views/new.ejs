<%- include('partials/header') %>

<div class="mb-6">
  <a href="/" class="back-link">← Volver</a>
</div>

<h1 class="title-primary" style="margin-bottom: 24px;">Nuevo tema</h1>

<form action="/topics" method="POST">
  <div class="form-group">
    <label class="label-text">Título</label>
    <input type="text" name="titulo" required class="input-field"/>
  </div>
  <div class="form-group">
    <label class="label-text">Descripción</label>
    <textarea name="descripcion" rows="3" class="textarea-field"></textarea>
  </div>
  <button type="submit" class="btn-primary" style="margin-top: 16px;">Crear tema</button>
</form>

<%- include('partials/footer') %>
