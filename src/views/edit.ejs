<%- include('partials/header') %>

<div class="mb-6">
  <a href="/" class="back-link">← Volver</a>
</div>

<h1 class="title-primary" style="margin-bottom: 24px;">Editar tema</h1>

<form action="/topics/<%= topic._id %>?_method=PUT" method="POST">
  <div class="form-group">
    <label class="label-text">Título</label>
    <input type="text" name="titulo" value="<%= topic.titulo %>" required class="input-field"/>
  </div>
  <div class="form-group">
    <label class="label-text">Descripción</label>
    <textarea name="descripcion" rows="3" class="textarea-field"><%= topic.descripcion %></textarea>
  </div>
  <button type="submit" class="btn-primary" style="margin-top: 16px;">Guardar cambios</button>
</form>

<%- include('partials/footer') %>
