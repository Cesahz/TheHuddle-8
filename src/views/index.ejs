<%- include('partials/header') %>

<div class="page-header">
  <h1 class="title-primary">Temas</h1>
  <a href="/topics/new" class="btn-primary">+ Nuevo tema</a>
</div>

<% if (topics.length === 0) { %>
  <p class="text-muted">No hay temas todavía.</p>
<% } %>

<% topics.forEach(topic => { %>
  <%- include('partials/topicCard', { topic: topic }) %>
<% }) %>

<%- include('partials/footer') %>